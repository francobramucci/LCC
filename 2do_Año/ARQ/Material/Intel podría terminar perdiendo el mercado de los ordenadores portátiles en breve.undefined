<style>*,:after,:before{box-sizing:border-box}*{margin:0}body,html{height:100%}body{line-height:1.5;-webkit-font-smoothing:antialiased}canvas,img,picture,svg,video{height:auto;max-width:100%}video{display:block}button,input,select,textarea{font:inherit}h1,h2,h3,h4,h5,h6,p{overflow-wrap:break-word}#__next,#root{isolation:isolate}html{background-color:var(--color-bg);max-width:100%;overflow-x:hidden;view-transition-name:root}body{color:var(--color-text);font-family:var(--gaz-font-base);font-size:18px;font-style:normal;font-weight:400;line-height:160%}body a{color:var(--color-link)}.nuxt-icon{margin-bottom:0!important;vertical-align:unset!important}button{background-color:transparent;border:0;cursor:pointer}select{background-color:var(--color-bg)!important}.main-container{margin:0 auto;max-width:100%;position:relative}@media (min-width:1400px){.main-container{max-width:1400px}}.main-container__inner{padding:8px}@media (min-width:375px){.main-container__inner{padding-left:16px;padding-right:16px}}@media (min-width:768px){.main-container__inner{padding-left:24px;padding-right:24px}}@media (min-width:375px){.main-container__inner{padding-bottom:16px;padding-top:16px}}@media (min-width:768px){.main-container__inner{padding-bottom:16px;padding-top:16px}}.main-container__inner--no-pt{padding-top:0}.sidebar-section{margin-bottom:48px}@media (min-width:768px){.sidebar-section{margin-bottom:80px}}.sidebar-section:last-child{margin-bottom:0}.flex-center{align-items:center;display:flex;justify-content:center}#t-pixel,#t-pixel img{height:0;width:0}::view-transition-old(root){animation:none}::view-transition-new(root){animation:none}html.dark::view-transition-new(root){animation:circle-reveal .45s ease-out forwards}html:not(.dark)::view-transition-new(root){animation:circle-reveal .45s ease-out forwards}@keyframes circle-reveal{0%{clip-path:circle(0 at 100% 0)}to{clip-path:circle(150% at 100% 0)}}.section-title{color:var(--color-heading);font-family:var(--gaz-font);font-size:30px;font-style:normal;font-weight:700;line-height:110%;margin:0 0 16px;padding-top:16px;position:relative}.section-title:after{background-color:var(--color-heading-line);content:"";height:4px;left:-8px;position:absolute;top:0;width:calc(100% + 16px)}@media (min-width:375px){.section-title:after{left:-16px;width:calc(100% + 32px)}}@media (min-width:768px){.section-title:after{left:-24px;width:calc(100% + 48px)}}.section-title--small{font-size:24px;line-height:120%}.section-title--medium{font-size:30px;line-height:110%}.section-title--large{font-size:48px;line-height:110%}.section-title--bottom-line{margin-bottom:0;padding:0 0 5px}.section-title--bottom-line:after{background-color:#0078ff;bottom:0;content:"";height:4px;left:0;position:absolute;top:auto;width:100%}.gaz-branded-link a,.gaz-button{align-items:center;background:var(--color-button-bg);border:0;border-radius:4px;color:var(--color-button-text);cursor:pointer;display:inline-flex;font-family:var(--gaz-font);font-size:14px;font-style:normal;font-weight:600;gap:16px;justify-content:center;line-height:120%;padding:12px 16px;text-align:center;text-decoration:none;text-transform:uppercase;transition:all .3s ease}.gaz-branded-link a:hover,.gaz-button:hover{background:var(--color-button-bg-hover);color:var(--color-button-text-hover)}.gaz-button--rounded{border-radius:24px}.gaz-button--corte-ingles{background:#8c8}.gaz-button--full-width{width:100%}.gaz-button--small{font-family:var(--gaz-font);font-size:11px;font-style:normal;font-weight:600;height:28px;line-height:100%;padding:4px 8px}.gaz-button--secondary{background:var(--color-button-secondary-bg);color:var(--color-button-secondary-text)}.gaz-button--secondary:hover{background:var(--color-button-secondary-bg-hover);color:var(--color-button-secondary-text-hover)}.gaz-button--tertiary{background:var(--color-button-tertiary-bg);border:1px solid var(--color-button-border);color:var(--color-button-tertiary-text)}.gaz-button--tertiary:hover{background:var(--color-button-ter