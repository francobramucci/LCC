17.7 15.441a9.68 9.68 0 0 0 1.857-5.711c0-5.365-4.365-9.73-9.732-9.73C4.46 0 .095 4.365.095 9.73s4.365 9.73 9.73 9.73a9.68 9.68 0 0 0 5.488-1.698L21.55 24zM2.95 9.73a6.885 6.885 0 0 1 6.877-6.877 6.885 6.885 0 0 1 6.877 6.877 6.885 6.885 0 0 1-6.877 6.877A6.884 6.884 0 0 1 2.95 9.73"></path></svg></button><div class="main-header__user-zone" data-v-f0c56840><div id="user-menu" class="user-menu" data-v-f0c56840 data-v-30493d2f><div class="user-menu__btn disabled" data-mrf-recirculation="header-user-btn" data-v-30493d2f><svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" class="nuxt-icon nuxt-icon--fill user-menu__icon" data-v-30493d2f><path d="M12 0C5.373 0 0 5.373 0 12s5.373 12 12 12 12-5.373 12-12S18.627 0 12 0m7.753 18.305c-.261-.586-.789-.991-1.871-1.241-2.293-.529-4.428-.993-3.393-2.945C17.634 8.177 15.322 5 12 5c-3.388 0-5.644 3.299-2.489 9.119 1.066 1.964-1.148 2.427-3.393 2.945-1.084.25-1.608.658-1.867 1.246A9.95 9.95 0 0 1 2 12C2 6.486 6.486 2 12 2s10 4.486 10 10a9.96 9.96 0 0 1-2.247 6.305"></path></svg></div><!----></div><div data-v-f0c56840 data-v-bd9dcf99><button class="color-scheme-btn" aria-label="Cambiar modo de color" data-mrf-recirculation="header-color-scheme-btn" data-v-bd9dcf99><svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" class="nuxt-icon nuxt-icon--fill color-scheme-btn__icon" data-v-bd9dcf99><path d="M12 0C5.373 0 0 5.373 0 12s5.373 12 12 12 12-5.373 12-12S18.627 0 12 0m4.95 5.636 1.414 1.414-2.195 2.195a5 5 0 0 0-1.414-1.414zM11 4h2v3.101a5 5 0 0 0-2 0zM7.05 5.636l2.195 2.195a5 5 0 0 0-1.414 1.415L5.636 7.05zM4 11h3.101a5 5 0 0 0 0 2H4zm3.05 7.364L5.636 16.95l2.195-2.195a5 5 0 0 0 1.414 1.414zM13 20h-2v-3.101a5 5 0 0 0 2 0zm-1-5a3 3 0 1 1 0-6 3 3 0 0 1 0 6m4.95 3.364-2.195-2.195a5 5 0 0 0 1.414-1.414l2.195 2.195zM20 13h-3.101a5 5 0 0 0 0-2H20z"></path></svg></button></div></div></div></header><header id="trends" class="trends-header" data-mrf-recirculation="trends-nav" data-v-f0c56840 data-v-a602cda1><nav class="trends" d